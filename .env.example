# =============================================================================
# Variables públicas leídas por Vite (deben empezar por VITE_).
# En Vercel se configuran en: Settings → Environment Variables.
# =============================================================================

# URL del backend FastAPI que crea las Stripe Checkout Sessions.
# - Dev/test: la URL pública de ngrok que reenvía a tu backend local.
# - Producción: dominio real cuando deployes el backend (Railway/Fly/Render).
VITE_API_BASE_URL=https://net-perish-football.ngrok-free.dev

# Publishable key (solo necesaria si mantienes el flujo inline /pago).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Solo lo usa la función serverless `api/create-payment-intent.js` (flujo
# inline en /pago). Si todo el flujo pasa por Stripe Checkout (recomendado),
# puedes dejarla vacía.
# =============================================================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
