# =============================================================================
# Frontend — Vite expone SOLO variables prefijadas con VITE_
# =============================================================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Backend — funciones serverless en /api. NO empiezan con VITE_ (no se filtran al cliente).
# =============================================================================

# Stripe — pago real.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — creación de usuarios del dashboard tras pago verificado.
# Usa el MISMO proyecto Supabase que el dashboard (saas-dashboard).
# Service role key se obtiene en: Supabase Dashboard → Settings → API → service_role
# IMPORTANTE: el service_role nunca debe filtrarse al cliente.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxx...

# Opcional — webhook para notificación de nuevos leads (Make / Zapier / n8n / Discord).
# Si no está definido, los leads solo van a Vercel Logs.
LEAD_WEBHOOK_URL=
